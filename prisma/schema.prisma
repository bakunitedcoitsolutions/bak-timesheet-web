// Prisma Schema for Timesheet Management System
// Database: Supabase PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTHENTICATION & AUTHORIZATION
// ============================================
// Note: Account and Session models are not needed since we're using:
// - CredentialsProvider (email/password) - no Account model needed
// - JWT session strategy - no Session model needed
// If you want to add OAuth providers (Google, GitHub, etc.) in the future,
// you'll need to add back the Account model.

model User {
  id          Int      @id @default(autoincrement())
  nameEn      String
  nameAr      String?
  email       String   @unique
  password    String? // Hashed password
  userRoleId  Int
  branchId    Int? // Required for Branch Manager (roleId: 3), optional for others
  isActive    Boolean  @default(true)
  createdBy   Int? // ID of user who created this record
  updatedBy   Int? // ID of user who last updated this record
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Relations: User → Other Tables (User has foreign keys)
  userRole   UserRole       @relation(fields: [userRoleId], references: [id])
  branch     Branch?        @relation("UserBranch", fields: [branchId], references: [id])
  privileges UserPrivilege?
  creator    User?          @relation("UserCreatedBy", fields: [createdBy], references: [id])
  updater    User?          @relation("UserUpdatedBy", fields: [updatedBy], references: [id])

  // Relations: Other Tables → User (Other tables have foreign keys pointing to User)
  // Auth & Roles
  createdUsers     User[]     @relation("UserCreatedBy")
  updatedUsers     User[]     @relation("UserUpdatedBy")
  createdUserRoles      UserRole[]      @relation("UserRoleCreatedBy")
  updatedUserRoles      UserRole[]      @relation("UserRoleUpdatedBy")
  createdUserPrivileges UserPrivilege[] @relation("UserPrivilegeCreatedBy")
  updatedUserPrivileges UserPrivilege[] @relation("UserPrivilegeUpdatedBy")

  // Branches & Locations
  createdBranches   Branch[]   @relation("BranchCreatedBy")
  updatedBranches   Branch[]   @relation("BranchUpdatedBy")
  createdCities     City[]     @relation("CityCreatedBy")
  updatedCities     City[]     @relation("CityUpdatedBy")
  createdCountries  Country[]  @relation("CountryCreatedBy")
  updatedCountries  Country[]  @relation("CountryUpdatedBy")
  createdGosiCities GosiCity[] @relation("GosiCityCreatedBy")
  updatedGosiCities GosiCity[] @relation("GosiCityUpdatedBy")

  // Employees
  createdEmployees        Employee[]       @relation("EmployeeCreatedBy")
  updatedEmployees        Employee[]       @relation("EmployeeUpdatedBy")
  createdDesignations     Designation[]    @relation("DesignationCreatedBy")
  updatedDesignations     Designation[]    @relation("DesignationUpdatedBy")
  createdEmployeeStatuses EmployeeStatus[] @relation("EmployeeStatusCreatedBy")
  updatedEmployeeStatuses EmployeeStatus[] @relation("EmployeeStatusUpdatedBy")

  // Projects & Timesheets
  createdProjects   Project[]   @relation("ProjectCreatedBy")
  updatedProjects   Project[]   @relation("ProjectUpdatedBy")
  createdTimesheets Timesheet[] @relation("TimesheetCreatedBy")
  updatedTimesheets Timesheet[] @relation("TimesheetUpdatedBy")

  // Payroll
  createdPayrollSections  PayrollSection[]  @relation("PayrollSectionCreatedBy")
  updatedPayrollSections  PayrollSection[]  @relation("PayrollSectionUpdatedBy")
  createdPayrollStatuses  PayrollStatus[]   @relation("PayrollStatusCreatedBy")
  updatedPayrollStatuses  PayrollStatus[]   @relation("PayrollStatusUpdatedBy")
  createdPayrollSummaries PayrollSummary[]  @relation("PayrollSummaryCreatedBy")
  updatedPayrollSummaries PayrollSummary[]  @relation("PayrollSummaryUpdatedBy")
  createdPaymentMethods   PaymentMethod[]   @relation("PaymentMethodCreatedBy")
  updatedPaymentMethods   PaymentMethod[]   @relation("PaymentMethodUpdatedBy")
  createdPayrollDetails   PayrollDetails[]  @relation("PayrollDetailsCreatedBy")
  updatedPayrollDetails   PayrollDetails[]  @relation("PayrollDetailsUpdatedBy")
  createdAllowancesNotAvailable AllowanceNotAvailable[] @relation("AllowanceNotAvailableCreatedBy")
  updatedAllowancesNotAvailable AllowanceNotAvailable[] @relation("AllowanceNotAvailableUpdatedBy")

  // Financial & Tracking
  createdLoans           Loan[]           @relation("LoanCreatedBy")
  updatedLoans           Loan[]           @relation("LoanUpdatedBy")
  createdTrafficChallans TrafficChallan[] @relation("TrafficChallanCreatedBy")
  updatedTrafficChallans TrafficChallan[] @relation("TrafficChallanUpdatedBy")
  createdExitReentries   ExitReentry[]    @relation("ExitReentryCreatedBy")
  updatedExitReentries   ExitReentry[]    @relation("ExitReentryUpdatedBy")

  @@index([email])
  @@index([userRoleId])
  @@index([branchId])
  @@index([createdBy])
  @@index([updatedBy])
}

// ============================================
// USER ROLES & PERMISSIONS
// ============================================

model UserRole {
  id        Int      @id @default(autoincrement())
  nameEn    String
  nameAr    String?
  access    String // Admin, Manager, Branch Manager, Access-Enabled User
  isActive  Boolean  @default(true)
  createdBy Int?
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  users   User[]
  creator User?  @relation("UserRoleCreatedBy", fields: [createdBy], references: [id])
  updater User?  @relation("UserRoleUpdatedBy", fields: [updatedBy], references: [id])

  @@index([createdBy])
  @@index([updatedBy])
}

model UserPrivilege {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  privileges Json // Stores UserPrivileges structure
  createdBy Int?
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations: UserPrivilege → Other Tables (UserPrivilege has foreign keys)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator User? @relation("UserPrivilegeCreatedBy", fields: [createdBy], references: [id])
  updater User? @relation("UserPrivilegeUpdatedBy", fields: [updatedBy], references: [id])

  @@index([createdBy])
  @@index([updatedBy])
}

// ============================================
// BRANCHES & LOCATIONS
// ============================================

model Branch {
  id             Int      @id @default(autoincrement())
  nameEn         String
  nameAr         String?
  isMain         Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdBy      Int?
  updatedBy      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  // Relations: Other Tables → Branch (Other tables have foreign keys pointing to Branch)
  users            User[]           @relation("UserBranch")
  subBranchUsers   Employee[]       @relation("EmployeeSubBranch")
  employees        Employee[]
  projects         Project[]
  payrollSummaries PayrollSummary[]
  payrollDetails   PayrollDetails[]
  payrollSections  PayrollSection[]
  creator          User?            @relation("BranchCreatedBy", fields: [createdBy], references: [id])
  updater          User?            @relation("BranchUpdatedBy", fields: [updatedBy], references: [id])

  @@index([createdBy])
  @@index([updatedBy])
}

model City {
  id        Int     @id @default(autoincrement())
  nameEn    String
  nameAr    String?
  countryId Int?
  isActive  Boolean @default(true)
  createdBy Int?
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations: City → Other Tables (City has foreign keys)
  country Country? @relation("CityCountry", fields: [countryId], references: [id])
  creator User?    @relation("CityCreatedBy", fields: [createdBy], references: [id])
  updater User?    @relation("CityUpdatedBy", fields: [updatedBy], references: [id])

  // Relations: Other Tables → City (Other tables have foreign keys pointing to City)
  employees Employee[]

  @@index([createdBy])
  @@index([updatedBy])
}

model Country {
  id        Int      @id @default(autoincrement())
  nameEn    String
  nameAr    String?
  isActive  Boolean  @default(true)

  createdBy Int?
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations: Other Tables → Country (Other tables have foreign keys pointing to Country)
  cities                 City[]     @relation("CityCountry")
  employeesByCountry     Employee[] @relation("EmployeeCountry")
  employeesByNationality Employee[] @relation("EmployeeNationality")
  creator                User?      @relation("CountryCreatedBy", fields: [createdBy], references: [id])
  updater                User?      @relation("CountryUpdatedBy", fields: [updatedBy], references: [id])

  @@index([createdBy])
  @@index([updatedBy])
}

model GosiCity {
  id        Int      @id @default(autoincrement())
  nameEn    String
  nameAr    String?
  isActive  Boolean  @default(true)
  createdBy Int?
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  employees Employee[]
  creator   User?      @relation("GosiCityCreatedBy", fields: [createdBy], references: [id])
  updater   User?      @relation("GosiCityUpdatedBy", fields: [updatedBy], references: [id])

  @@index([createdBy])
  @@index([updatedBy])
}

// ============================================
// EMPLOYEES
// ============================================

model Employee {
  // Step 1
  id             Int       @id @default(autoincrement())
  profilePicture String?
  employeeCode   Int       @unique
  nameEn         String
  nameAr         String?
  dob            DateTime? @db.Date
  phone          String?

  // Step 2
  gender             String? // Male, Female
  countryId          Int?
  cityId             Int?
  statusId           Int?
  branchId           Int?
  subBranchId        Int?
  designationId      Int?
  payrollSectionId   Int?
  isDeductable       Boolean   @default(false)
  isFixed            Boolean   @default(false)
  workingDays        Int?
  hourlyRate         Decimal   @db.Decimal(10, 2)
  salary             Int?
  breakfastAllowance Boolean   @default(false)
  foodAllowance      Int?
  mobileAllowance    Int?
  otherAllowance     Int?
  contractStartDate  DateTime? @db.Date
  contractEndDate    DateTime? @db.Date
  contractDocument   String?
  contractEndReason  String?   @db.Text
  joiningDate        DateTime? @db.Date

  // Step 3
  idCardNo           String?
  idCardExpiryDate   DateTime? @db.Date
  idCardDocument     String?
  profession         String?
  nationalityId      Int?
  passportNo         String?
  passportExpiryDate DateTime? @db.Date
  passportDocument   String?

  lastExitDate  DateTime? @db.Date
  lastEntryDate DateTime? @db.Date

  // Step 4
  bankName   String?
  bankCode   String?
  iban       String?
  gosiSalary Int?
  gosiCityId Int?

  // Step 5 - Loan & Bank Card Details
  isCardDelivered Boolean @default(false)
  cardDocument    String?

  createdBy Int?
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations: Employee → Other Tables (Employee has foreign keys)
  country        Country?        @relation("EmployeeCountry", fields: [countryId], references: [id])
  nationality    Country?        @relation("EmployeeNationality", fields: [nationalityId], references: [id])
  city           City?           @relation(fields: [cityId], references: [id])
  status         EmployeeStatus? @relation(fields: [statusId], references: [id])
  branch         Branch?         @relation(fields: [branchId], references: [id])
  subBranch      Branch?         @relation("EmployeeSubBranch", fields: [subBranchId], references: [id])
  designation    Designation?    @relation(fields: [designationId], references: [id])
  payrollSection PayrollSection? @relation(fields: [payrollSectionId], references: [id])
  gosiCity       GosiCity?       @relation(fields: [gosiCityId], references: [id])
  creator        User?           @relation("EmployeeCreatedBy", fields: [createdBy], references: [id])
  updater        User?           @relation("EmployeeUpdatedBy", fields: [updatedBy], references: [id])

  // Relations: Other Tables → Employee (Other tables have foreign keys pointing to Employee)
  timesheets      Timesheet[]
  loans           Loan[]
  trafficChallans TrafficChallan[]
  exitReentries   ExitReentry[]
  payrollDetails  PayrollDetails[]

  @@index([employeeCode])
  @@index([countryId])
  @@index([branchId])
  @@index([statusId])
  @@index([createdBy])
  @@index([updatedBy])
}

model Designation {
  id              Int      @id @default(autoincrement())
  nameEn          String
  nameAr          String?
  hoursPerDay     Int?
  displayOrderKey Int?
  color           String? // Hex color code (e.g., #3B82F6)
  isActive        Boolean  @default(true)
  createdBy       Int?
  updatedBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  // Relations: Other Tables → Designation (Other tables have foreign keys pointing to Designation)
  employees     Employee[]
  exitReentries ExitReentry[]
  creator       User?         @relation("DesignationCreatedBy", fields: [createdBy], references: [id])
  updater       User?         @relation("DesignationUpdatedBy", fields: [updatedBy], references: [id])

  @@index([createdBy])
  @@index([updatedBy])
}

model EmployeeStatus {
  id        Int      @id @default(autoincrement())
  nameEn    String
  nameAr    String?
  isActive  Boolean  @default(true)
  createdBy Int?
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations: Other Tables → EmployeeStatus (Other tables have foreign keys pointing to EmployeeStatus)
  employees Employee[]
  creator   User?      @relation("EmployeeStatusCreatedBy", fields: [createdBy], references: [id])
  updater   User?      @relation("EmployeeStatusUpdatedBy", fields: [updatedBy], references: [id])

  @@index([createdBy])
  @@index([updatedBy])
}

// ============================================
// PROJECTS
// ============================================

model Project {
  id          Int      @id @default(autoincrement())
  nameEn      String
  nameAr      String?
  branchId    Int?
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Relations: Project → Other Tables (Project has foreign keys)
  branch  Branch? @relation(fields: [branchId], references: [id])
  creator User?   @relation("ProjectCreatedBy", fields: [createdBy], references: [id])
  updater User?   @relation("ProjectUpdatedBy", fields: [updatedBy], references: [id])

  // Relations: Other Tables → Project (Other tables have foreign keys pointing to Project)
  timesheetsAsProject1 Timesheet[] @relation("TimesheetProject1")
  timesheetsAsProject2 Timesheet[] @relation("TimesheetProject2")

  @@index([createdBy])
  @@index([updatedBy])
}

// ============================================
// TIMESHEETS
// ============================================

model Timesheet {
  id               Int      @id @default(autoincrement())
  employeeId       Int
  date             DateTime @db.Date // Compulsory date field
  project1Id       Int?
  project1Hours    Int?
  project1Overtime Int?
  project2Id       Int?
  project2Hours    Int?
  project2Overtime Int?
  totalHours       Int?
  description      String?  @db.Text
  isLocked         Boolean  @default(false)
  isManual         Boolean  @default(false)
  createdBy        Int?
  updatedBy        Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  // Relations: Timesheet → Other Tables (Timesheet has foreign keys)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project1 Project? @relation("TimesheetProject1", fields: [project1Id], references: [id], onDelete: Cascade)
  project2 Project? @relation("TimesheetProject2", fields: [project2Id], references: [id], onDelete: Cascade)
  creator  User?    @relation("TimesheetCreatedBy", fields: [createdBy], references: [id])
  updater  User?    @relation("TimesheetUpdatedBy", fields: [updatedBy], references: [id])

  @@index([employeeId])
  @@index([date])
  @@index([project1Id])
  @@index([project2Id])
  @@index([createdBy])
  @@index([updatedBy])
}

// ============================================
// PAYROLL DETAILS & SUMMARY
// ============================================

model PayrollSection {
  id              Int      @id @default(autoincrement())
  nameEn          String
  nameAr          String?
  branchId        Int?     @default(1)
  displayOrderKey Int?
  isActive        Boolean  @default(true)
  createdBy       Int?
  updatedBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  // Relations: Project → Other Tables (Project has foreign keys)
  branch   Branch? @relation(fields: [branchId], references: [id])
  creator  User?   @relation("PayrollSectionCreatedBy", fields: [createdBy], references: [id])
  updater  User?   @relation("PayrollSectionUpdatedBy", fields: [updatedBy], references: [id])
  employees Employee[]

  @@index([createdBy])
  @@index([updatedBy])
}

model PayrollStatus {
  id        Int      @id @default(autoincrement())
  nameEn    String
  nameAr    String?
  isActive  Boolean  @default(true)
  createdBy Int?
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations: Other Tables → PayrollStatus (Other tables have foreign keys pointing to PayrollStatus)
  summaries      PayrollSummary[]
  payrollDetails PayrollDetails[]
  creator        User?            @relation("PayrollStatusCreatedBy", fields: [createdBy], references: [id])
  updater        User?            @relation("PayrollStatusUpdatedBy", fields: [updatedBy], references: [id])

  @@index([createdBy])
  @@index([updatedBy])
}

model PayrollSummary {
  id                      Int      @id @default(autoincrement())
  payrollMonth            Int
  payrollYear             Int
  totalSalary             Int
  totalBreakfastAllowance Int
  totalOtherAllowances    Int
  totalPreviousLoan       Int
  totalCurrentLoan        Int
  totalLoanDeduction      Int
  totalNetLoan            Int
  totalPreviousChallan    Int
  totalCurrentChallan     Int
  totalChallanDeduction   Int
  totalNetChallan         Int
  totalNetSalaryPayable   Int
  totalCardSalary         Int
  totalCashSalary         Int
  remarks                 String?  @db.Text
  payrollStatusId         Int?
  branchId                Int?
  createdBy               Int?
  updatedBy               Int?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt

  // Relations: PayrollSummary → Other Tables (PayrollSummary has foreign keys)
  branch        Branch?        @relation(fields: [branchId], references: [id])
  payrollStatus PayrollStatus? @relation(fields: [payrollStatusId], references: [id])
  creator       User?          @relation("PayrollSummaryCreatedBy", fields: [createdBy], references: [id])
  updater       User?          @relation("PayrollSummaryUpdatedBy", fields: [updatedBy], references: [id])

  // Relations: Other Tables → PayrollSummary
  details PayrollDetails[]

  @@index([payrollMonth, payrollYear])
  @@index([branchId])
  @@index([payrollStatusId])
  @@index([createdBy])
  @@index([updatedBy])
}

model PaymentMethod {
  id        Int      @id @default(autoincrement())
  nameEn    String
  nameAr    String?
  isActive  Boolean  @default(true)
  createdBy Int?
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations: Other Tables → PaymentMethod
  payrollDetails PayrollDetails[]
  creator        User?            @relation("PaymentMethodCreatedBy", fields: [createdBy], references: [id])
  updater        User?            @relation("PaymentMethodUpdatedBy", fields: [updatedBy], references: [id])

  @@index([createdBy])
  @@index([updatedBy])
}

model PayrollDetails {
  id                        Int      @id @default(autoincrement())
  payrollId                 Int
  payrollMonth              Int
  payrollYear               Int
  employeeId                Int
  workDays                  Int
  totalHours                Int
  hourlyRate                Decimal  @db.Decimal(10, 2)
  breakfastAllowance        Int
  tripAllowance             Int      @default(0)
  overtimeAllowance         Int      @default(0)
  otherAllowances           Int
  totalAllowances           Int
  salary                    Int
  previousLoan              Int
  currentLoan               Int
  loanDeduction             Int
  netLoan                   Int
  previousChallan           Int
  currentChallan            Int
  challanDeduction          Int
  netChallan                Int
  netSalaryPayable          Int
  cardSalary                Int
  cashSalary                Int
  overTime                  Int
  remarks                   String?  @db.Text
  paymentMethodId           Int?
  payrollStatusId           Int?
  branchId                  Int?
  allowanceNotAvailableId   Int?
  createdBy                 Int?
  updatedBy                 Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @default(now()) @updatedAt
  isLocked                  Boolean  @default(false)

  // Relations: PayrollDetails → Other Tables
  payrollSummary        PayrollSummary         @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employee              Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  paymentMethod         PaymentMethod?         @relation(fields: [paymentMethodId], references: [id])
  payrollStatus         PayrollStatus?         @relation(fields: [payrollStatusId], references: [id])
  branch                Branch?                @relation(fields: [branchId], references: [id])
  allowanceNotAvailable AllowanceNotAvailable? @relation(fields: [allowanceNotAvailableId], references: [id])
  creator               User?                  @relation("PayrollDetailsCreatedBy", fields: [createdBy], references: [id])
  updater               User?                  @relation("PayrollDetailsUpdatedBy", fields: [updatedBy], references: [id])

  @@index([payrollId])
  @@index([employeeId])
  @@index([payrollMonth, payrollYear])
  @@index([branchId])
  @@index([payrollStatusId])
  @@index([paymentMethodId])
  @@index([createdBy])
  @@index([updatedBy])
}

// ============================================
// LOANS
// ============================================

enum LoanType {
  LOAN
  RETURN
}

model Loan {
  id         Int      @id @default(autoincrement())
  employeeId Int
  date       DateTime @db.Date
  type       LoanType
  amount     Int
  remarks    String?  @db.Text
  createdBy  Int?
  updatedBy  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  // Relations: Loan → Other Tables (Loan has foreign keys)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  creator  User?    @relation("LoanCreatedBy", fields: [createdBy], references: [id])
  updater  User?    @relation("LoanUpdatedBy", fields: [updatedBy], references: [id])

  @@index([employeeId])
  @@index([date])
  @@index([type])
  @@index([createdBy])
  @@index([updatedBy])
}

// ============================================
// TRAFFIC CHALLANS
// ============================================

enum TrafficChallanType {
  CHALLAN
  RETURN
}

model TrafficChallan {
  id          Int                @id @default(autoincrement())
  employeeId  Int
  date        DateTime           @db.Date
  type        TrafficChallanType
  amount      Int
  description String?            @db.Text
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @default(now()) @updatedAt

  // Relations: TrafficChallan → Other Tables (TrafficChallan has foreign keys)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  creator  User?    @relation("TrafficChallanCreatedBy", fields: [createdBy], references: [id])
  updater  User?    @relation("TrafficChallanUpdatedBy", fields: [updatedBy], references: [id])

  @@index([employeeId])
  @@index([date])
  @@index([type])
  @@index([createdBy])
  @@index([updatedBy])
}

// ============================================
// EXIT & RE-ENTRY
// ============================================

enum ExitReentryType {
  EXIT
  ENTRY
}

model ExitReentry {
  id            Int             @id @default(autoincrement())
  employeeId    Int
  designationId Int?
  date          DateTime        @db.Date
  type          ExitReentryType
  remarks       String?         @db.Text
  createdBy     Int?
  updatedBy     Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt

  // Relations: ExitReentry → Other Tables (ExitReentry has foreign keys)
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  designation Designation? @relation(fields: [designationId], references: [id])
  creator     User?        @relation("ExitReentryCreatedBy", fields: [createdBy], references: [id])
  updater     User?        @relation("ExitReentryUpdatedBy", fields: [updatedBy], references: [id])

  @@index([employeeId])
  @@index([designationId])
  @@index([date])
  @@index([type])
  @@index([createdBy])
  @@index([updatedBy])
}

enum AllowanceType {
  BREAKFAST
  FOOD
  MOBILE
  OTHER
}

model AllowanceNotAvailable {
  id          Int           @id @default(autoincrement())
  nameEn      String // e.g., "Ramadan 2026"
  nameAr      String? // e.g., "رمضان 2026"
  description String?       @db.Text // Optional description/reason
  startDate   DateTime      @db.Date // Start date of the exclusion period
  endDate     DateTime      @db.Date // End date of the exclusion period
  type        AllowanceType // Type of allowance to exclude (BREAKFAST)
  isActive    Boolean       @default(true) // Allow soft disable without deletion
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt

  payrollDetails PayrollDetails[]
  creator        User?            @relation("AllowanceNotAvailableCreatedBy", fields: [createdBy], references: [id])
  updater        User?            @relation("AllowanceNotAvailableUpdatedBy", fields: [updatedBy], references: [id])

  @@index([startDate])
  @@index([endDate])
  @@index([type])
  @@index([isActive])
  @@index([createdBy])
  @@index([updatedBy])
}
